{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(gateway_http_requests_total[1m])",
          "legendFormat": "{{instance}} {{method}} {{route}}"
        }
      ]
    },
    {
      "title": "Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(gateway_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "title": "Transactions Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(gateway_transactions_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "title": "Transactions by Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum by (card_type) (gateway_transactions_total)",
          "legendFormat": "{{card_type}}"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(gateway_http_requests_total{status_code=~\"5..\"}[1m])",
          "legendFormat": "{{instance}} {{route}}"
        }
      ]
    },
    {
      "title": "PostgreSQL Replication Lag (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "pg_replication_lag",
          "legendFormat": "Replication Lag"
        }
      ]
    },
    {
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{datname}} ({{state}})"
        }
      ]
    },
    {
      "title": "Availability SLI (Success Rate %)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(gateway_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(gateway_http_requests_total[5m]))))",
          "legendFormat": "Availability %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 99, "color": "yellow" },
              { "value": 99.9, "color": "green" }
            ]
          },
          "min": 95,
          "max": 100,
          "unit": "percent"
        }
      }
    },
    {
      "title": "Error Budget Remaining",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(gateway_http_requests_total{status_code=~\"5..\"}[24h])) / (sum(rate(gateway_http_requests_total[24h])) * 0.001)))",
          "legendFormat": "Budget %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 25, "color": "yellow" },
              { "value": 50, "color": "green" }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gateway", "ha", "sre"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Gateway HA - Observability Dashboard",
  "uid": "gateway-ha-dashboard"
}
