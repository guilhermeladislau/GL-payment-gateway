# Exemplo de terraform.tfvars
# Copie este arquivo para terraform.tfvars e ajuste conforme necessário.

# Socket Docker (ajustar conforme SO)
# Linux:  unix:///var/run/docker.sock
# macOS:  unix:///Users/<usuario>/.docker/run/docker.sock
# docker_host = "unix:///var/run/docker.sock"

# Portas externas (padrão se não definidas)
# lb_port          = 8080
# pg_primary_port  = 5432
# pg_replica_port  = 5433
# prometheus_port  = 9090
# grafana_port     = 3001
